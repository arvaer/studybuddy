  "query": "\n            UPDATE topics SET\n                name        = COALESCE($3, name),\n                description = COALESCE($4, description),\n                color       = COALESCE($5, color)\n            WHERE id = $1 AND user_id = $2\n            RETURNING id, user_id, name, description, color, created_at\n            ",
