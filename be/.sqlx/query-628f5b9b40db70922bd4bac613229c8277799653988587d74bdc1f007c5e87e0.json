{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, user_id, concept_id, ru_id, content, is_ai_generated,\n                   anchor_position, created_at\n            FROM notes\n            WHERE user_id = $1\n              AND ($2::uuid IS NULL OR concept_id = $2)\n              AND ($3::uuid IS NULL OR ru_id = $3)\n            ORDER BY created_at DESC\n            ",
