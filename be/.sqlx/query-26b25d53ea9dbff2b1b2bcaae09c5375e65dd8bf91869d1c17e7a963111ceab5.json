{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, user_id, title, session_type::TEXT AS session_type,\n                   progress, started_at, completed_at\n            FROM study_sessions\n            WHERE user_id = $1\n              AND ($2::bool IS NULL\n                   OR ($2 = true  AND completed_at IS NOT NULL)\n                   OR ($2 = false AND completed_at IS NULL))\n            ORDER BY started_at DESC\n            ",
